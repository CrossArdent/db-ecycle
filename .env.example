SECRET_KEY=change-this-to-a-long-random-string

# SQLite path defaults to instance/warehouse_dashboard.sqlite3 if unset.
# DATABASE_PATH=instance/warehouse_dashboard.sqlite3

# SMTP notification settings. If any required value is missing, releases still
# succeed and the app logs a warning instead of sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
WAREHOUSE_MANAGER_EMAIL=
